{
  "name": "com.cliporax.qrscanner",
  "version": "1.0.0",
  "description": "QR Code Scanner Plugin for Cliporax",
  "main": "main.js",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --outfile=main.js --format=iife --platform=browser --target=es2020 --minify",
    "build:dev": "esbuild src/main.ts --bundle --outfile=main.js --format=iife --platform=browser --target=es2020",
    "watch": "esbuild src/main.ts --bundle --outfile=main.js --format=iife --platform=browser --target=es2020 --watch"
  },
  "dependencies": {
    "jsqr": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
