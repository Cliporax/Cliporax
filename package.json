{
  "name": "cliporax",
  "version": "1.1.1",
  "description": "A modern clipboard manager with privacy-first AI",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "plugins:build": "node scripts/build-plugins.mjs",
    "plugins:build:release": "node scripts/build-plugins.mjs --release",
    "plugins:bundle": "npm run plugins:build:release && node scripts/bundle-plugins.mjs",
    "plugins:install": "node scripts/install-plugins.mjs",
    "plugins:dev": "npm run plugins:build && node scripts/bundle-plugins.mjs && npm run plugins:install",
    "cli:prepare": "node scripts/prepare-cli-bin.mjs",
    "cli:prepare:release": "node scripts/prepare-cli-bin.mjs --release",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:install": "npm run tauri build && echo '✅ Build complete! Install the package from src-tauri/target/release/bundle/'",
    "codegen:types": "cd src-tauri && cargo build --features export-types",
    "cli:build": "cd src-tauri && cargo build --bin cliporax-cli",
    "cli:build:release": "cd src-tauri && cargo build --release --bin cliporax-cli",
    "cli:run": "cd src-tauri && cargo run --bin cliporax-cli --",
    "cli": "cd src-tauri && cargo run --quiet --bin cliporax-cli --",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": {
    "name": "Cliporax Team",
    "email": "cliporax@example.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.24",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.5.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.21",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-global-shortcut": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "i18next": "^26.0.3",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.2",
    "zustand": "^4.5.7"
  }
}
