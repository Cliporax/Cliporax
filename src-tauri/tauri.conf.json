{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cliporax",
  "version": "1.2.4",
  "identifier": "com.cliporax.app",
  "build": {
    "beforeDevCommand": "node scripts/tauri-before-dev.mjs",
    "beforeBuildCommand": "npm run build && npm run plugins:bundle && npm run cli:prepare:release",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Cliporax",
        "width": 800,
        "height": 600,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "visible": true,
        "center": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "deny": []
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage", "dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "icons": "icons",
      "builtin-plugins": "builtin-plugins"
    },
    "externalBin": ["bin/cliporax-cli"],
    "linux": {
      "deb": {
        "depends": ["xclip", "x11-utils"],
        "files": {
          "/usr/share/bash-completion/completions/cliporax-cli": "completions/cliporax.bash",
          "/usr/share/zsh/vendor-completions/_cliporax": "completions/_cliporax"
        }
      },
      "rpm": {
        "files": {
          "/usr/share/bash-completion/completions/cliporax-cli": "completions/cliporax.bash",
          "/usr/share/zsh/site-functions/_cliporax": "completions/_cliporax"
        }
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "entitlements": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
